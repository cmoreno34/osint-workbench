    var countHtml = "";
    if(state.data[k] && state.data[k].length>0){
      countHtml = ' <span class="count" style="background:'+v.color+'22;color:'+v.color+'">'+state.data[k].length+'</span>';
    }
    b.innerHTML = v.icon+" "+v.name+countHtml;
    b.onclick = function(){ state.tab=k; state.showCode=false; state.showJson=false; renderTabs(); render(); };
    bar.appendChild(b);
  });
}

function render(){
  var s = SOURCES[state.tab];
  var d = state.data[state.tab];
  var err = state.errors[state.tab];
  var loading = state.loading[state.tab];
  var html = "";
  
  // Status
  var total = 0;
  Object.values(state.data).forEach(function(v){ if(v) total+=v.length; });
  var badge = document.getElementById("statusBadge");
  if(total>0){ badge.style.display="inline"; badge.textContent=total+" results"; }
  else { badge.style.display="none"; }
  
  // API bar
  html += '<div class="api-bar"><div>';
  html += '<span class="api-name" style="color:'+s.color+'">'+s.icon+' '+s.name+'</span>';
  html += '<span class="api-badge">FREE</span>';
  html += '<p class="api-desc">'+s.desc+'</p></div>';
  html += '<div style="display:flex;gap:6px">';
  html += '<button class="btn-sm '+(state.showCode?"active-code":"")+'" onclick="toggleCode()">\u{1F40D} Python</button>';
  html += '<button class="btn-sm '+(state.showJson?"active-json":"")+'" onclick="toggleJson()">{ } JSON</button>';
  html += '</div></div>';
  
  // Code panel
  if(state.showCode){
    html += '<div class="code-panel"><div class="code-title"><span>\u{1F40D} Python - copy and run locally</span>';
    html += '<button class="code-copy" onclick="copyCode()">Copy</button></div>';
    html += '<pre class="code-pre" id="codeBlock">'+getPython(state.tab)+'</pre></div>';
  }
  
  // JSON panel
  if(state.showJson && d){
    html += '<div class="json-panel"><span class="json-title">Raw API response - '+d.length+' records</span>';
    html += '<pre class="json-pre">'+JSON.stringify(d.slice(0,4),null,2)+'</pre></div>';
  }
  
  // Error
  if(err){
    html += '<div class="error-box"><p style="font-size:11px;color:#fca5a5;font-weight:600">API Error: '+err+'</p>';
    html += '<p style="font-size:9px;color:#9c5555;margin-top:4px">Some APIs may have CORS restrictions. Use the Python code to run from your machine.</p></div>';
  }
  
  // Empty
  if(!d && !loading && !err){
    html += '<div class="empty"><div class="empty-icon">'+s.icon+'</div>';
    html += '<p style="font-size:14px;color:#4a5568">Type a company name and click <b style="color:#718096">Fetch All</b></p>';
    html += '<p style="font-size:11px;color:#2d3a5c;margin-top:6px">Real data from '+s.name+' will appear here</p></div>';
  }
  
  // Loading
  if(loading){
    html += '<div class="loading"><p style="font-size:13px;color:'+s.color+'">\u23F3 Calling '+s.name+'...</p></div>';
  }
  
  // Results
  if(d && !loading){
    if(d.length===0){
      html += '<p style="text-align:center;color:#4a5568;padding:30px;font-size:12px">No results for "'+state.company+'". Try the full legal name.</p>';
    }
    
    if(state.tab==="contracts"){
      d.forEach(function(c){
        html += '<div class="card"><div class="card-head">';
        html += '<div><span class="mono text-xs" style="color:#22c55e;font-weight:600">'+c.id+'</span>';
        html += ' <span class="text-xs text-muted">'+c.type+' - '+(c.start||"")+'</span></div>';
        html += '<span class="amount" style="color:#22c55e">'+fmt(c.amount)+'</span></div>';
        html += '<p class="text-sm text-light">\u{1F3DB}\uFE0F '+c.agency+(c.subAgency?' &gt; '+c.subAgency:'')+'</p>';
        html += '<p class="text-xs text-muted" style="line-height:1.4;margin-top:2px">'+c.desc+'</p></div>';
      });
    }
    
    if(state.tab==="sec"){
      d.forEach(function(f){
        html += '<div class="card"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">';
        html += '<span class="form-badge">'+f.form+'</span>';
        html += '<span class="text-xs text-muted">'+f.date+'</span>';
        if(f.period) html += '<span class="text-xs text-muted">Period: '+f.period+'</span>';
        html += '</div>';
        html += '<p class="text-base text-bright" style="font-weight:600">'+f.company+'</p>';
        if(f.location) html += '<p class="text-xs text-muted">'+f.location+'</p>';
        html += '</div>';
      });
    }
    
    if(state.tab==="patents"){
      d.forEach(function(p){
        html += '<div class="card"><div class="card-head">';
        html += '<span class="mono text-xs" style="color:#3b82f6;font-weight:600">US'+p.id+' - '+p.cpc+' - '+p.date+'</span>';
        var cColor = p.citedBy>20?"#ef4444":p.citedBy>5?"#eab308":"#718096";
        html += '<span class="text-xs" style="color:'+cColor+'">Claims: '+p.claims+' - Cited: '+p.citedBy+'</span></div>';
        html += '<h4 style="font-size:12px;font-weight:600;color:#edf2f7;margin-bottom:2px">'+p.title+'</h4>';
        html += '<p class="text-xs" style="color:#718096">'+p.assignee+'</p>';
        html += '<p class="text-xs text-muted" style="line-height:1.4;margin-top:2px">'+(p.abstract||"").slice(0,200)+'</p></div>';
      });
    }
    
    // AI button
    if(d.length>0){
      html += '<div class="ai-box"><div class="ai-head">';
      html += '<span class="ai-title">\u{1F9E0} AI Intelligence Analysis</span>';
      html += '<button class="btn-ai" onclick="runAI()" '+(state.aiLoading?'disabled':'')+'>'+
        (state.aiLoading?'Analyzing...':'\u26A1 Analyze with Claude')+'</button></div>';
      if(state.ai[state.tab]){
        html += '<div class="ai-result"><pre class="ai-text">'+state.ai[state.tab]+'</pre></div>';
      }
      html += '</div>';
    }
  }
  
  document.getElementById("mainContent").innerHTML = html;
}

// ═══ DATA FETCHING ═══
function doSearch(c){
  document.getElementById("searchInput").value = c;
  state.company = c;
  fetchAll();
}

function fetchAll(){
  state.company = document.getElementById("searchInput").value.trim();
  if(!state.company) return;
  
  // Check preloaded first
  if(PRELOADED_CONTRACTS[state.company]){
    state.data.contracts = PRELOADED_CONTRACTS[state.company];
    state.errors.contracts = null;
  } else {
    fetchContracts(state.company);
  }
  
  if(PRELOADED_SEC[state.company]){
    state.data.sec = PRELOADED_SEC[state.company];
    state.errors.sec = null;
  } else {
    fetchSECLive(state.company);
  }
  
  fetchPatentsLive(state.company);
  
  state.ai = {};
  renderTabs();
  render();
}

async function fetchContracts(q){
  state.loading.contracts = true; state.errors.contracts = null; render();
  try{
    var r = await fetch("https://api.usaspending.gov/api/v2/search/spending_by_award/",{
      method:"POST", headers:{"Content-Type":"application/json"},
      body: JSON.stringify({filters:{recipient_search_text:[q],time_period:[{start_date:"2020-01-01",end_date:"2025-12-31"}],award_type_codes:["A","B","C","D"]},
        fields:["Award ID","Recipient Name","Award Amount","Awarding Agency","Awarding Sub Agency","Award Type","Description","Start Date","End Date"],
        limit:15,order:"desc",sort:"Award Amount",subawards:false,page:1})
    });
    var d = await r.json();
    state.data.contracts = (d.results||[]).map(function(x){
      return {id:x["Award ID"]||"N/A",recipient:x["Recipient Name"]||"",amount:x["Award Amount"]||0,
        agency:x["Awarding Agency"]||"",subAgency:x["Awarding Sub Agency"]||"",type:x["Award Type"]||"",
        desc:(x["Description"]||"").slice(0,200),start:x["Start Date"]||"",end:x["End Date"]||""};
    });
  }catch(e){ state.errors.contracts = e.message; }
  state.loading.contracts = false; renderTabs(); render();
}

async function fetchPatentsLive(q){
  state.loading.patents = true; state.errors.patents = null; render();
  try{
    var qObj = JSON.stringify({"_and":[{"_or":[{"assignees.assignee_organization":{"_contains":q}},{"patent_title":{"_contains":q}}]}]});
    var fObj = JSON.stringify(["patent_id","patent_title","patent_date","patent_abstract","assignees.assignee_organization","cpcs.cpc_group_id","patent_num_cited_by_us_patents","patent_num_claims"]);
    var sObj = JSON.stringify([{"patent_date":"desc"}]);
    var oObj = JSON.stringify({"size":12});
    var url = "https://search.patentsview.org/api/v1/patent/?q="+encodeURIComponent(qObj)+"&f="+encodeURIComponent(fObj)+"&s="+encodeURIComponent(sObj)+"&o="+encodeURIComponent(oObj);
    var r = await fetch(url,{headers:{Accept:"application/json"}});
    if(!r.ok) throw new Error("HTTP "+r.status);
    var d = await r.json();
    state.data.patents = (d.patents||[]).map(function(p){
      return {id:p.patent_id,title:p.patent_title||"Untitled",date:p.patent_date||"",
        abstract:p.patent_abstract||"",assignee:(p.assignees&&p.assignees[0]&&p.assignees[0].assignee_organization)||"",
        cpc:(p.cpcs&&p.cpcs[0]&&p.cpcs[0].cpc_group_id)||"N/A",
        citedBy:p.patent_num_cited_by_us_patents||0,claims:p.patent_num_claims||0};
    });
  }catch(e){ state.errors.patents = e.message; }
  state.loading.patents = false; renderTabs(); render();
}

async function fetchSECLive(q){
  state.loading.sec = true; state.errors.sec = null; render();
  try{
    var r = await fetch("https://efts.sec.gov/LATEST/search-index?q=%22"+encodeURIComponent(q)+"%22&dateRange=custom&startdt=2020-01-01&enddt=2025-12-31&forms=10-K,10-Q,8-K&from=0&size=12",
      {headers:{"User-Agent":"CIcourse academic@university.edu"}});
    if(!r.ok) throw new Error("HTTP "+r.status);
    var d = await r.json();
    state.data.sec = ((d.hits&&d.hits.hits)||[]).map(function(h){
      var src = h._source||{};
      return {date:src.file_date||"",form:src.form||"",company:(src.display_names&&src.display_names[0])||q,
        location:(src.biz_locations&&src.biz_locations[0])||"",period:src.period_ending||""};
    });
  }catch(e){ state.errors.sec = e.message; }
  state.loading.sec = false; renderTabs(); render();
}

// ═══ AI ANALYSIS ═══
async function runAI(){
  var d = state.data[state.tab];
  if(!d||!d.length) return;
  state.aiLoading = true; render();
  try{
    var r = await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:800,
        system:"You are a competitive intelligence analyst. Analyze this "+SOURCES[state.tab].name+" data for "+state.company+". Give: 3 strategic signals (mark HIGH/MEDIUM/LOW), 1 blind spot, 1 recommendation. Be specific, cite data. Under 200 words.",
        messages:[{role:"user",content:JSON.stringify(d.slice(0,6))}]})
    });
    var data = await r.json();
    state.ai[state.tab] = (data.content&&data.content[0]&&data.content[0].text)||"Analysis unavailable";
  }catch(e){ state.ai[state.tab] = "Error: "+e.message; }
  state.aiLoading = false; render();
}

// ═══ CODE & TOGGLES ═══
function toggleCode(){ state.showCode=!state.showCode; state.showJson=false; render(); }
function toggleJson(){ state.showJson=!state.showJson; state.showCode=false; render(); }
function copyCode(){
  var el = document.getElementById("codeBlock");
  if(el) navigator.clipboard.writeText(el.textContent);
}

function getPython(tab){
  var q = state.company || "Raytheon";
  if(tab==="contracts") return 'import requests\n\nresp = requests.post(\n    "https://api.usaspending.gov/api/v2/search/spending_by_award/",\n    json={\n        "filters": {\n            "recipient_search_text": ["'+q+'"],\n            "time_period": [{"start_date": "2020-01-01", "end_date": "2025-12-31"}],\n            "award_type_codes": ["A", "B", "C", "D"]\n        },\n        "fields": ["Award ID", "Recipient Name", "Award Amount",\n                   "Awarding Agency", "Description", "Start Date"],\n        "limit": 25, "order": "desc", "sort": "Award Amount"\n    }\n)\nfor a in resp.json()["results"][:5]:\n    print(f"${a[\'Award Amount\']:,.0f}  |  {a[\'Awarding Agency\']}")\n    print(f"  {a[\'Description\'][:80]}")';
  if(tab==="patents") return 'import requests, json\n\nresp = requests.get(\n    "https://search.patentsview.org/api/v1/patent/",\n    params={\n        "q": json.dumps({"_and": [\n            {"assignees.assignee_organization": {"_contains": "'+q+'"}}\n        ]}),\n        "f": json.dumps(["patent_id", "patent_title", "patent_date",\n            "patent_abstract", "patent_num_cited_by_us_patents"]),\n        "s": json.dumps([{"patent_date": "desc"}]),\n        "o": json.dumps({"size": 25})\n    }\n)\nfor p in resp.json()["patents"][:5]:\n    print(f"US{p[\'patent_id\']}: {p[\'patent_title\']}")\n    print(f"  Cited by: {p[\'patent_num_cited_by_us_patents\']} patents")';
  return 'import requests\n\nresp = requests.get(\n    "https://efts.sec.gov/LATEST/search-index",\n    params={\n        "q": \'"'+q+'"\'  ,\n        "forms": "10-K,10-Q,8-K",\n        "dateRange": "custom",\n        "startdt": "2020-01-01",\n        "enddt": "2025-12-31"\n    },\n    headers={"User-Agent": "CI_Course academic@uni.edu"}\n)\nfor f in resp.json()["hits"]["hits"][:5]:\n    s = f["_source"]\n    print(f"{s[\'form\']}  |  {s[\'file_date\']}")\n    print(f"  {s[\'display_names\'][0]}")';
}

